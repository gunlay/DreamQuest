.container {
  padding: 20px;
  background: #fff;
  box-sizing: border-box;
  width: 100%;
}

.title {
  font-size: 24px;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30px;
}

.content {
  width: 100%;
}

.section {
  margin-bottom: 24px;
  width: 100%;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 12px;
  padding-right: 16px;
}

.section-content {
  font-size: 14px;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
  word-wrap: break-word;
  word-break: break-all;
  padding-right: 16px;
} 