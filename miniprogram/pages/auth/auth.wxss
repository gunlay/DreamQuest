/* pages/auth/auth.wxss */
/* 页面样式 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 24px;
  margin-bottom: 20px;
}

.auth-button {
  padding: 10px 20px;
  background-color: #1aad19;
  color: #fff;
  font-size: 16px;
  border-radius: 5px;
  border: none;
}
