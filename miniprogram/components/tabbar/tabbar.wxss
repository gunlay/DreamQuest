.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 49px;
  background: rgba(253, 253, 253, 0.92);
  backdrop-filter: blur(48px);
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 0.5px solid rgba(0, 0, 0, 0.1);
  z-index: 9999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.tab-icon {
  width: 24px;
  height: 24px;
}

.tab-text {
  font-size: 10px;
  text-align: center;
}

.login-btn {
  box-sizing: border-box;
  width: 148px;
  height: 33px;
  background: linear-gradient( 252deg, #971FCF 0%, #6920D6 100%);
  box-shadow: 1px 4px 4px 0px rgba(151,31,207,0.37);
  border-radius: 13px 13px 13px 13px;
  padding: 4px 12px;
}

.login-btn .tab-text {
  font-weight: 600;
  font-size: 14px;
  color: #FFFFFF;
  line-height: 26px;
}